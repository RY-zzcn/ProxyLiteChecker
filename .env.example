APP_NAME=ProxyLiteChecker
APP_VERSION=0.2.0
TZ=Asia/Shanghai
HOST=0.0.0.0
PORT=8899
DATABASE_URL=sqlite:///./data/proxylite.db

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
SECRET_KEY=change-this-secret
ACCESS_TOKEN_MINUTES=1440
PLC_REQUIRE_SECURE=0

# Empty means authenticated users can export. Set a token for unauthenticated
# scripts: /api/export/proxies.txt?token=...
PLC_EXPORT_TOKEN=

# Local HTTP proxy gateway. It binds to 0.0.0.0 by default so local Docker
# containers and other machines can consume the checked proxy pool when allowed
# by your firewall.
PLC_GATEWAY_ENABLED=1
PLC_GATEWAY_HOST=0.0.0.0
PLC_GATEWAY_PORT=18080
PLC_GATEWAY_TARGET_PROFILES=all
PLC_GATEWAY_PROFILE_PORT_STRIDE=2
# Optional per-target overrides, for example:
# PLC_GATEWAY_HTTP_PROFILE_PORTS=generic:18080,openai:18082,grok:18084,gemini:18086,claude:18088
# PLC_GATEWAY_SOCKS5_PROFILE_PORTS=generic:18081,openai:18083,grok:18085,gemini:18087,claude:18089
PLC_SOCKS5_GATEWAY_ENABLED=1
PLC_SOCKS5_GATEWAY_HOST=0.0.0.0
PLC_SOCKS5_GATEWAY_PORT=18081
PLC_GATEWAY_UPSTREAM_LIMIT=200
